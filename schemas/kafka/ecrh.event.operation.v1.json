{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operation Event",
  "type": "object",
  "required": [
    "source_system",
    "shot_no",
    "event_family",
    "event_time",
    "event_code"
  ],
  "properties": {
    "source_system": {"type": "string"},
    "authority_level": {"type": "string"},
    "correlation_key": {"type": "string"},
    "source_entity_id": {"type": "string"},
    "shot_no": {"type": "integer"},
    "artifact_id": {"type": "string"},
    "event_family": {"type": "string", "enum": ["OPERATION"]},
    "event_code": {"type": "string"},
    "event_name": {"type": "string"},
    "event_time": {"type": "string", "format": "date-time"},
    "process_id": {"type": "string"},
    "channel_name": {"type": "string"},
    "message_text": {"type": "string"},
    "message_level": {"type": "string"},
    "severity": {"type": "string"},
    "dedup_key": {"type": "string"},
    "details": {
      "type": "object",
      "properties": {
        "operation_type_code": {"type": "string"},
        "operation_mode_code": {"type": "string"},
        "operation_task_code": {"type": "string"},
        "channel_name": {"type": "string"},
        "old_value": {"type": "number"},
        "new_value": {"type": "number"},
        "delta_value": {"type": "number"},
        "confidence": {"type": "number"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
